{# @var plugin \arbsn\craftbuildtrigger\Plugin #}
{# @var settings \arbsn\craftbuildtrigger\models\Settings #}

{% import '_includes/forms.twig' as forms %}

<h2>{{ "Build Trigger Settings"|t('build-trigger') }}</h2>

<p>{{ "Configure a build hook URL per site. Leave a site blank to disable its build trigger. Environment variables are supported (e.g. {var})."|t('build-trigger', { var: '$NETLIFY_BUILD_HOOK' }) }}</p>

{% for site in craft.app.sites.allSites %}
    {{ forms.autosuggestField({
        label: site.name,
        instructions: "Build hook URL for #{site.handle}"|t('build-trigger'),
        id: "buildHookUrls-#{site.uid}",
        name: "buildHookUrls[#{site.uid}]",
        value: settings.getBuildHookUrl(site.uid),
        suggestEnvVars: true,
        placeholder: 'https://api.netlify.com/build_hooks/…',
    }) }}
{% endfor %}
