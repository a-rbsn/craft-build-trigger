{% extends "_layouts/cp.twig" %}
{% import '_includes/forms.twig' as forms %}
{% set title = "Build Trigger"|t('build-trigger') %}

{% set settings = craft.app.plugins.getPlugin('build-trigger').getSettings() %}

{% block content %}
    {% set sitesWithHook = craft.app.sites.allSites|filter(site => settings.getBuildHookUrl(site.uid) is not empty) %}

    {% if sitesWithHook is empty %}
        <p>
            {{ "No build hooks are configured yet."|t('build-trigger') }}
            <a href="{{ url('settings/plugins/build-trigger') }}">{{ "Configure build hooks"|t('build-trigger') }}</a>
        </p>
    {% else %}
        <div class="buttons">
            {% for site in sitesWithHook %}
                <form method="POST" style="display:inline-block">
                    {{ csrfInput() }}
                    {{ actionInput('build-trigger/default/trigger-build') }}
                    {{ redirectInput('build-trigger') }}
                    {{ hiddenInput('siteId', site.id) }}
                    <button type="submit" class="btn submit" data-loading-text="{{ 'Triggering build…'|t('build-trigger') }}">
                        {{ 'Trigger build: {site}'|t('build-trigger', { site: site.name }) }}
                    </button>
                </form>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
